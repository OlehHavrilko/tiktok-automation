{
  "name": "tiktok-automation-project",
  "version": "1.0.0",
  "description": "TikTok content creation and automation using free APIs and tools",
  "main": "scripts/main.py",
  "scripts": {
    "start": "source venv/bin/activate && python scripts/main.py",
    "research": "source venv/bin/activate && python scripts/research_trends.py",
